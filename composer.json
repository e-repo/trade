{
  "name": "symfony/shop",
  "type": "project",
  "license": "MIT",
  "description": "Garden shop application",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "doctrine/dbal": "^3.9",
    "doctrine/doctrine-bundle": "^2.13",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "doctrine/orm": "^3.2.6",
    "fakerphp/faker": "^1.23",
    "nelmio/api-doc-bundle": "^4.26",
    "nelmio/cors-bundle": "^2.5",
    "nesbot/carbon": "^3.8",
    "ramsey/uuid": "*",
    "scienta/doctrine-json-functions": "^6.1",
    "symfony/asset": "7.4.*",
    "symfony/console": "7.4.*",
    "symfony/dotenv": "7.4.*",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "7.4.*",
    "symfony/mailer": "7.4.*",
    "symfony/messenger": "7.4.*",
    "symfony/monolog-bundle": "^3.10",
    "symfony/property-access": "7.4.*",
    "symfony/runtime": "7.4.*",
    "symfony/security-bundle": "7.4.*",
    "symfony/serializer": "7.4.*",
    "symfony/string": "7.4.*",
    "symfony/twig-bundle": "7.4.*",
    "symfony/validator": "7.4.*",
    "symfony/yaml": "7.4.*",
    "twig/extra-bundle": "^3.0",
    "twig/twig": "^3.0"
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "Trade\\": "src/Trade",
      "CoreKit\\": "src/CoreKit"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Test\\": "tests/Test"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*",
    "symfony/polyfill-php83": "*"
  },
  "scripts": {
    "captainhook:install": "./captainhook-install.sh",
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts",
      "@captainhook:install"
    ],
    "post-update-cmd": [
      "@auto-scripts",
      "@captainhook:install"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "7.4.*"
    }
  },
  "require-dev": {
    "captainhook/captainhook": "^5.23",
    "dama/doctrine-test-bundle": "^8.2",
    "doctrine/doctrine-fixtures-bundle": "^3.6",
    "liip/test-fixtures-bundle": "^2.10",
    "phpunit/php-code-coverage": "^13.0",
    "phpunit/phpunit": "^13.0.5",
    "symfony/browser-kit": "7.4.*",
    "symfony/css-selector": "7.4.*",
    "symfony/maker-bundle": "^1.61",
    "symfony/phpunit-bridge": "^7.4",
    "symplify/easy-coding-standard": "^12.3",
    "zenstruck/messenger-test": "^1.11"
  }
}
